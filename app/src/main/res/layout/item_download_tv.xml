<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@drawable/bg_tv_item_focus">

    <ImageView
        android:id="@+id/iv_poster"
        android:layout_width="100dp"
        android:layout_height="150dp"
        android:scaleType="centerCrop"
        android:background="#1A1A1A"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintEnd_toStartOf="@id/btn_action"
        app:layout_constraintStart_toEndOf="@id/iv_poster"
        app:layout_constraintTop_toTopOf="@id/iv_poster"
        tools:text="Movie Title" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:textColor="#99FFFFFF"
        android:textSize="14sp"
        android:maxLines="1"
        app:layout_constraintStart_toEndOf="@id/iv_poster"
        app:layout_constraintEnd_toStartOf="@id/btn_action"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        tools:text="S1 E3 - Episode Title" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:textColor="#66FFFFFF"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/iv_poster"
        app:layout_constraintEnd_toStartOf="@id/btn_action"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        tools:text="Downloading... 45%" />

    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progressTint="#BB86FC"
        android:progressBackgroundTint="#333333"
        app:layout_constraintStart_toEndOf="@id/iv_poster"
        app:layout_constraintEnd_toStartOf="@id/btn_action"
        app:layout_constraintTop_toBottomOf="@id/tv_status" />

    <!-- Single action button (pause/resume/retry/delete) — focusable for D-pad -->
    <ImageView
        android:id="@+id/btn_action"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="10dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:background="@drawable/bg_tv_button_focus"
        app:layout_constraintEnd_toStartOf="@id/btn_delete"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="ContentDescription" />

    <!-- Delete/cancel button -->
    <ImageView
        android:id="@+id/btn_delete"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:padding="10dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:background="@drawable/bg_tv_button_focus"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="ContentDescription"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
